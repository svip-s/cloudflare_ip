不# --- 资源地址配置 ---
INPUT_URL="https://zip.cm.edu.kg/all.txt"

# --- TCP 延迟测试参数 ---
TCP_WORKERS=400
TCP_TIMEOUT=1.5

# --- 下载测速参数 ---
SPEED_WORKERS=12
SPEED_TIMEOUT=10.0
MIN_SPEED=8.0
SPEED_PROCESS_BUFFER=8.0
TOP_PER_REGION=10

# --- GitHub 配置 ---
GH_TOKEN="ghp_Token..."
GH_REPO="https://github.com/用户名/仓库名.git"

# --- Cloudflare R2 配置 ---
ACCOUNT_ID="账户 ID"
ACCESS_KEY="访问密钥 ID"
SECRET_KEY="机密访问密钥"
BUCKET_NAME="存储桶名称"

# --- Telegram 通知配置 ---
TG_TOKEN="你创建的机器人 Token"
TG_CHAT_ID="你的自己或者频道的 Chat ID"
TG_PROXY_DOMAIN="你创建的 Workers 代理域名"

# 注意：配置中不要有多余的空格回车或者符号，有可能会出现意想不到的异常情况。
